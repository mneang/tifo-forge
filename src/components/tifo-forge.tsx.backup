"use client";

import { AnimatePresence, motion } from "motion/react";
import {
  type RefObject,
  useMemo,
  useRef,
  useState,
} from "react";

import styles from "./tifo-forge.module.css";

import {
  emotionIds,
  fallbackTifoDesign,
  symbolIds,
  teamIds,
  type TifoDesign,
} from "@/lib/tifo-schema";
import {
  emotions,
  symbols,
  teams,
  type EmotionId,
  type SymbolId,
  type TeamId,
} from "@/lib/tifo-options";

type DesignResponse = {
  ok: boolean;
  source: "gemini" | "fallback";
  design: TifoDesign;
  warning?: string;
  error?: string;
};

type TifoSelection = {
  team: TeamId;
  emotion: EmotionId;
  symbol: SymbolId;
};

type Palette = {
  primary: string;
  secondary: string;
  accent: string;
};

function SymbolGlyph({
  symbol,
  color,
  outlineColor = "#020617",
}: {
  symbol: SymbolId;
  color: string;
  outlineColor?: string;
}) {
  const outlineStyle = {
    paintOrder: "stroke fill" as const,
    stroke: outlineColor,
    strokeWidth: 10,
    strokeLinejoin: "round" as const,
  };

  if (symbol === "crown") {
    return (
      <g
        fill="none"
        stroke={color}
        strokeLinecap="round"
        strokeLinejoin="round"
      >
        <path
          d="M12 69 18 28 40 48 50 15 60 48 82 28 88 69Z"
          strokeWidth="6"
          style={outlineStyle}
        />
        <path
          d="M17 70H83V84H17Z"
          fill={color}
          strokeWidth="6"
          style={outlineStyle}
        />
        <circle cx="18" cy="27" r="4" fill={color} />
        <circle cx="50" cy="14" r="4" fill={color} />
        <circle cx="82" cy="27" r="4" fill={color} />
      </g>
    );
  }

  if (symbol === "phoenix") {
    return (
      <g
        fill="none"
        stroke={color}
        strokeLinecap="round"
        strokeLinejoin="round"
      >
        <path
          d="M50 12C57 29 67 37 88 24C84 44 72 55 58 53C70 65 65 82 50 92C35 82 30 65 42 53C28 55 16 44 12 24C33 37 43 29 50 12Z"
          strokeWidth="7"
          style={outlineStyle}
        />
        <path
          d="M50 27C41 41 41 56 50 73C59 56 59 41 50 27Z"
          fill={color}
          strokeWidth="4"
          style={outlineStyle}
        />
      </g>
    );
  }

  if (symbol === "lightning") {
    return (
      <polygon
        points="58,6 23,55 45,55 35,94 78,42 55,42"
        fill={color}
        style={outlineStyle}
      />
    );
  }

  if (symbol === "heart") {
    return (
      <path
        d="M50 88 16 56C-7 34 8 8 31 13C41 15 48 24 50 32C52 24 59 15 69 13C92 8 107 34 84 56Z"
        fill={color}
        style={outlineStyle}
      />
    );
  }

  if (symbol === "rising-sun") {
    return (
      <g
        fill="none"
        stroke={color}
        strokeLinecap="round"
        strokeLinejoin="round"
      >
        <circle
          cx="50"
          cy="55"
          r="21"
          fill={color}
          style={outlineStyle}
        />

        <path
          d="M50 8V23M18 21L29 33M82 21L71 33M6 55H21M94 55H79M18 86L30 74M82 86L70 74"
          strokeWidth="7"
          style={outlineStyle}
        />

        <path
          d="M10 88H90"
          strokeWidth="8"
          style={outlineStyle}
        />
      </g>
    );
  }

  return (
    <g
      fill="none"
      stroke={color}
      strokeLinecap="round"
      strokeLinejoin="round"
    >
      <path
        d="M47 72C32 79 18 74 8 62C26 61 35 49 39 30C45 43 48 57 47 72Z"
        strokeWidth="7"
        style={outlineStyle}
      />
      <path
        d="M53 72C68 79 82 74 92 62C74 61 65 49 61 30C55 43 52 57 53 72Z"
        strokeWidth="7"
        style={outlineStyle}
      />
      <path
        d="M50 29V86"
        strokeWidth="7"
        style={outlineStyle}
      />
      <path
        d="M38 82 50 91 62 82"
        strokeWidth="7"
        style={outlineStyle}
      />
    </g>
  );
}

function hexToRgb(hex: string) {
  const cleanHex = hex.replace("#", "");

  if (cleanHex.length !== 6) {
    return { r: 255, g: 255, b: 255 };
  }

  return {
    r: Number.parseInt(cleanHex.slice(0, 2), 16),
    g: Number.parseInt(cleanHex.slice(2, 4), 16),
    b: Number.parseInt(cleanHex.slice(4, 6), 16),
  };
}

function getLuminance(hex: string) {
  const { r, g, b } = hexToRgb(hex);

  const channels = [r, g, b].map((channel) => {
    const normalized = channel / 255;

    return normalized <= 0.03928
      ? normalized / 12.92
      : Math.pow((normalized + 0.055) / 1.055, 2.4);
  });

  return (
    channels[0] * 0.2126 +
    channels[1] * 0.7152 +
    channels[2] * 0.0722
  );
}

function pickHighContrastColor(palette: Palette) {
  const candidates = [
    palette.accent,
    palette.secondary,
    "#FFFFFF",
    "#F8FAFC",
  ];

  return candidates.sort(
    (first, second) =>
      getLuminance(second) - getLuminance(first),
  )[0];
}

function isSymbolSeat(
  symbol: SymbolId,
  row: number,
  column: number,
  rows: number,
  columns: number,
) {
  const x =
    (column - (columns - 1) / 2) / (columns / 2);

  const y =
    (row - (rows - 1) / 2) / (rows / 2);

  if (symbol === "heart") {
    const adjustedY = y + 0.08;

    const value =
      Math.pow(
        x * x +
          adjustedY * adjustedY -
          0.48,
        3,
      ) -
      x * x *
        Math.pow(adjustedY, 3);

    return value < 0 && adjustedY < 0.72;
  }

  if (symbol === "lightning") {
    const upperStroke =
      Math.abs(x + 0.24 - y * 0.28) < 0.13 &&
      y < 0.18;

    const lowerStroke =
      Math.abs(x - 0.12 - y * 0.36) < 0.13 &&
      y > -0.2;

    return upperStroke || lowerStroke;
  }

  if (symbol === "crown") {
    const base =
      y > 0.28 &&
      y < 0.58 &&
      Math.abs(x) < 0.64;

    const leftPoint =
      y > -0.42 &&
      y < 0.32 &&
      Math.abs(x + 0.48) <
        0.14 + (y + 0.42) * 0.22;

    const centerPoint =
      y > -0.66 &&
      y < 0.32 &&
      Math.abs(x) <
        0.13 + (y + 0.66) * 0.16;

    const rightPoint =
      y > -0.42 &&
      y < 0.32 &&
      Math.abs(x - 0.48) <
        0.14 + (y + 0.42) * 0.22;

    return base || leftPoint || centerPoint || rightPoint;
  }

  if (symbol === "rising-sun") {
    const circle =
      x * x + Math.pow(y + 0.05, 2) < 0.2;

    const horizon =
      Math.abs(y - 0.45) < 0.09 &&
      Math.abs(x) < 0.72;

    const verticalRay =
      Math.abs(x) < 0.08 &&
      y > -0.72 &&
      y < -0.22;

    const diagonalRay =
      Math.abs(Math.abs(x) + y - 0.65) < 0.11 &&
      y < -0.08;

    return circle || horizon || verticalRay || diagonalRay;
  }

  if (symbol === "wings") {
    const leftWing =
      x < -0.06 &&
      x > -0.82 &&
      Math.abs(y - (-0.05 - x * 0.32)) < 0.16;

    const rightWing =
      x > 0.06 &&
      x < 0.82 &&
      Math.abs(y - (-0.05 + x * 0.32)) < 0.16;

    const spine =
      Math.abs(x) < 0.08 &&
      y > -0.38 &&
      y < 0.58;

    return leftWing || rightWing || spine;
  }

  const leftWing =
    x < -0.04 &&
    x > -0.78 &&
    Math.abs(y - (-0.08 - x * 0.36)) < 0.15;

  const rightWing =
    x > 0.04 &&
    x < 0.78 &&
    Math.abs(y - (-0.08 + x * 0.36)) < 0.15;

  const body =
    Math.abs(x) < 0.1 &&
    y > -0.54 &&
    y < 0.66;

  const tail =
    y > 0.32 &&
    Math.abs(x) < 0.28 - (y - 0.32) * 0.2;

  return leftWing || rightWing || body || tail;
}

function darkenHex(hex: string, factor: number) {
  const { r, g, b } = hexToRgb(hex);

  const clamp = (value: number) =>
    Math.max(0, Math.min(255, Math.round(value)));

  return `#${[
    clamp(r * factor),
    clamp(g * factor),
    clamp(b * factor),
  ]
    .map((channel) => channel.toString(16).padStart(2, "0"))
    .join("")}`;
}

function getSeatColor(
  layout: TifoDesign["layout"],
  symbol: SymbolId,
  row: number,
  column: number,
  rows: number,
  columns: number,
  palette: Palette,
  symbolColor: string,
) {
  const centerRow = (rows - 1) / 2;
  const centerColumn = (columns - 1) / 2;

  const normalizedX =
    (column - centerColumn) / (columns / 2);

  const normalizedY =
    (row - centerRow) / (rows / 2);

  const centerDistance = Math.sqrt(
    normalizedX * normalizedX +
      normalizedY * normalizedY,
  );

  if (
    isSymbolSeat(
      symbol,
      row,
      column,
      rows,
      columns,
    )
  ) {
    return symbolColor;
  }

  const distance = Math.sqrt(
    Math.pow((row - centerRow) / rows, 2) * 5 +
      Math.pow((column - centerColumn) / columns, 2) *
        2.5,
  );

  let baseColor: string;

  if (layout === "center-emblem") {
    baseColor =
      (row + column) % 2 === 0
        ? palette.primary
        : palette.secondary;
  } else if (layout === "diagonal-rise") {
    const diagonal = column - row * 1.55;

    if (diagonal > 8 && diagonal < 14) {
      baseColor = palette.accent;
    } else {
      baseColor =
        diagonal >= 14
          ? palette.secondary
          : palette.primary;
    }
  } else if (layout === "split-banner") {
    if (Math.abs(column - centerColumn) < 2.4) {
      baseColor = palette.accent;
    } else {
      baseColor =
        column < centerColumn
          ? palette.primary
          : palette.secondary;
    }
  } else {
    baseColor =
      Math.floor(distance * 13) % 2 === 0
        ? palette.primary
        : palette.secondary;
  }

  if (centerDistance < 0.34) {
    return darkenHex(baseColor, 0.32);
  }

  if (centerDistance < 0.5) {
    return darkenHex(baseColor, 0.62);
  }

  return baseColor;
}

function getPassionMotion(emotion: EmotionId) {
  if (emotion === "defy") {
    return {
      initial: {
        opacity: 0,
        x: -34,
        y: 14,
        skewX: -4,
        scale: 0.98,
      },
      animate: {
        opacity: [0, 1, 1],
        x: [-34, 8, 0],
        y: [14, -3, 0],
        skewX: [-4, 1, 0],
        scale: [0.98, 1.025, 1],
      },
    };
  }

  if (emotion === "unite") {
    return {
      initial: {
        opacity: 0,
        scaleX: 0.72,
        scaleY: 0.96,
      },
      animate: {
        opacity: [0, 1, 1],
        scaleX: [0.72, 1.035, 1],
        scaleY: [0.96, 1.015, 1],
      },
    };
  }

  if (emotion === "remember") {
    return {
      initial: {
        opacity: 0,
        y: 5,
        scale: 0.975,
      },
      animate: {
        opacity: [0, 0.72, 1],
        y: [5, 1, 0],
        scale: [0.975, 1.008, 1],
      },
    };
  }

  return {
    initial: {
      opacity: 0,
      y: 32,
      scale: 0.97,
    },
    animate: {
      opacity: [0, 1, 1],
      y: [32, -7, 0],
      scale: [0.97, 1.025, 1],
    },
  };
}

function getSloganFontSize(slogan: string) {
  if (slogan.length <= 12) {
    return 58;
  }

  if (slogan.length <= 18) {
    return 52;
  }

  if (slogan.length <= 22) {
    return 46;
  }

  return 41;
}

function StadiumPreview({
  team,
  emotion,
  symbol,
  design,
  generationId,
  isGenerating,
  svgRef,
}: {
  team: TeamId;
  emotion: EmotionId;
  symbol: SymbolId;
  design: TifoDesign;
  generationId: number;
  isGenerating: boolean;
  svgRef: RefObject<SVGSVGElement | null>;
}) {
  const teamData = teams[team];

  const rows = 13;
  const columns = 30;

  const seats = useMemo(
    () =>
      Array.from(
        { length: rows * columns },
        (_, index) => {
          const row = Math.floor(index / columns);
          const column = index % columns;
          const rowWidth = 850 + row * 14;
          const gap = rowWidth / columns;
          const startX = 600 - rowWidth / 2;

          return {
            index,
            row,
            column,
            x: startX + column * gap + 3,
            y: 176 + row * 28,
            width: Math.max(19, gap - 6),
          };
        },
      ),
    [],
  );

  const intensity =
    Math.max(60, Math.min(100, design.energy)) / 100;

  const revealDuration =
    emotion === "remember"
      ? 1.75
      : 1.55 - intensity * 0.22;

  const symbolDelay = revealDuration * 0.47;
  const bannerDelay = revealDuration * 0.68;
  const sloganDelay = revealDuration * 0.82;
  const finalPulseDelay = sloganDelay + 0.48;

  const symbolColor = pickHighContrastColor(
    teamData.colors,
  );

  const outlineColor =
    getLuminance(symbolColor) > 0.65
      ? "#020617"
      : "#FFFFFF";

  const passionMotion =
    getPassionMotion(emotion);

  const sloganFontSize =
    getSloganFontSize(design.slogan);

  return (
    <div className={styles.stadiumShell}>
      {isGenerating && (
        <motion.div
          className={styles.loadingOverlay}
          initial={{ opacity: 0 }}
          animate={{ opacity: 1 }}
        >
          <motion.div
            className={styles.loadingPill}
            animate={{
              scale: [1, 1.035, 1],
            }}
            transition={{
              duration: 1,
              repeat: Infinity,
              ease: "easeInOut",
            }}
          >
            <span />
            Gemini is directing the stand
          </motion.div>
        </motion.div>
      )}

      <motion.svg
        ref={svgRef}
        key={generationId}
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 1200 720"
        className={styles.stadium}
        initial={{
          opacity: 0.92,
          scale: 0.992,
          y: 4,
        }}
        animate={{
          opacity: 1,
          scale: [0.992, 1.012, 1],
          y: [4, -3, 0],
        }}
        transition={{
          duration: finalPulseDelay + 0.9,
          times: [0, 0.74, 1],
          ease: [0.16, 1, 0.3, 1],
        }}
        role="img"
        aria-label={`${teamData.name} supporter tifo reading ${design.slogan}`}
      >
        <defs>
          <linearGradient
            id={`sky-${generationId}`}
            x1="0"
            y1="0"
            x2="0"
            y2="1"
          >
            <stop offset="0%" stopColor="#020617" />
            <stop offset="50%" stopColor="#111c36" />
            <stop offset="100%" stopColor="#020617" />
          </linearGradient>

          <linearGradient
            id={`pitch-${generationId}`}
            x1="0"
            y1="0"
            x2="0"
            y2="1"
          >
            <stop offset="0%" stopColor="#166534" />
            <stop offset="100%" stopColor="#052e16" />
          </linearGradient>

          <linearGradient
            id={`shine-${generationId}`}
            x1="0"
            y1="0"
            x2="1"
            y2="0"
          >
            <stop
              offset="0%"
              stopColor="#ffffff"
              stopOpacity="0"
            />
            <stop
              offset="50%"
              stopColor="#ffffff"
              stopOpacity="0.24"
            />
            <stop
              offset="100%"
              stopColor="#ffffff"
              stopOpacity="0"
            />
          </linearGradient>

          <radialGradient
            id={`final-flash-${generationId}`}
          >
            <stop
              offset="0%"
              stopColor="#ffffff"
              stopOpacity="0.44"
            />
            <stop
              offset="52%"
              stopColor={teamData.colors.primary}
              stopOpacity="0.18"
            />
            <stop
              offset="100%"
              stopColor={teamData.colors.primary}
              stopOpacity="0"
            />
          </radialGradient>

          <filter
            id={`glow-${generationId}`}
            x="-80%"
            y="-80%"
            width="260%"
            height="260%"
          >
            <feGaussianBlur
              stdDeviation={10 + intensity * 5}
            />
          </filter>

          <filter
            id={`text-glow-${generationId}`}
            x="-30%"
            y="-100%"
            width="160%"
            height="300%"
          >
            <feGaussianBlur stdDeviation="4" />
          </filter>
        </defs>

        <rect
          width="1200"
          height="720"
          fill={`url(#sky-${generationId})`}
        />

        <motion.ellipse
          cx="600"
          cy="225"
          rx="500"
          ry="230"
          fill={teamData.colors.primary}
          initial={{ opacity: 0.04 }}
          animate={{
            opacity: [
              0.04,
              0.12 + intensity * 0.16,
              0.09 + intensity * 0.12,
            ],
          }}
          transition={{
            duration: finalPulseDelay + 1,
            times: [0, 0.68, 1],
            ease: "easeOut",
          }}
        />

        <path
          d="M55 130Q600 25 1145 130L1112 164Q600 81 88 164Z"
          fill="#0f172a"
          stroke="#475569"
          strokeWidth="5"
        />

        {Array.from({ length: 20 }, (_, index) => (
          <motion.rect
            key={index}
            x={73 + index * 55}
            y="105"
            width="34"
            height="11"
            rx="4"
            fill="#ffffff"
            initial={{ opacity: 0.15 }}
            animate={{
              opacity: [
                0.15,
                0.75,
                1,
                0.78,
              ],
            }}
            transition={{
              delay: 0.04 + index * 0.014,
              duration: finalPulseDelay + 0.85,
              times: [0, 0.22, 0.78, 1],
            }}
          />
        ))}

        <path
          d="M60 152H1140L1090 603H110L60 152Z"
          fill="#111827"
          stroke="#475569"
          strokeWidth="6"
        />

        <path
          d="M82 167H1118L1070 578H130L82 167Z"
          fill="#020617"
          stroke="#1e293b"
          strokeWidth="3"
        />

        <motion.g
          initial={passionMotion.initial}
          animate={passionMotion.animate}
          transition={{
            duration: revealDuration,
            ease:
              emotion === "defy"
                ? [0.22, 1, 0.36, 1]
                : [0.16, 1, 0.3, 1],
          }}
          style={{
            transformOrigin: "600px 370px",
          }}
        >
          {seats.map(
            ({
              index,
              row,
              column,
              x,
              y,
              width,
            }) => (
              <rect
                key={index}
                x={x}
                y={y}
                width={width}
                height="18"
                rx="3"
                fill={getSeatColor(
                  design.layout,
                  symbol,
                  row,
                  column,
                  rows,
                  columns,
                  teamData.colors,
                  symbolColor,
                )}
              />
            ),
          )}
        </motion.g>

        <motion.rect
          x="60"
          y="158"
          width="245"
          height="420"
          rx="20"
          fill={`url(#shine-${generationId})`}
          initial={{
            opacity: 0,
            x: emotion === "defy" ? -380 : -300,
          }}
          animate={{
            opacity: [0, 0.68, 0],
            x: 1280,
          }}
          transition={{
            delay: 0.12,
            duration:
              emotion === "remember"
                ? revealDuration + 0.9
                : revealDuration + 0.45,
            ease: [0.16, 1, 0.3, 1],
          }}
          pointerEvents="none"
        />

        <motion.circle
          cx="600"
          cy="350"
          r="132"
          fill={symbolColor}
          filter={`url(#glow-${generationId})`}
          initial={{
            opacity: 0,
            scale: 0.45,
          }}
          animate={{
            opacity: [
              0,
              0.11 + intensity * 0.23,
              0.08 + intensity * 0.13,
            ],
            scale: [0.45, 1.06, 1],
          }}
          transition={{
            delay: symbolDelay,
            duration: 1.05,
            times: [0, 0.72, 1],
            ease: [0.16, 1, 0.3, 1],
          }}
          style={{
            transformOrigin: "600px 350px",
          }}
        />

        <motion.g
          transform="translate(495 243) scale(2.1)"
          initial={{
            opacity: 0,
            scale: 0.62,
            y: 18,
          }}
          animate={{
            opacity: 1,
            scale: [0.62, 1.08, 1],
            y: [18, -4, 0],
          }}
          transition={{
            delay: symbolDelay,
            duration: 0.86,
            times: [0, 0.72, 1],
            ease: [0.16, 1, 0.3, 1],
          }}
          style={{
            transformOrigin: "600px 350px",
          }}
        >
          <SymbolGlyph
            symbol={symbol}
            color={symbolColor}
            outlineColor={outlineColor}
          />
        </motion.g>

        <motion.g
          initial={{
            opacity: 0,
            y: 20,
            scaleX: 0.78,
          }}
          animate={{
            opacity: 1,
            y: 0,
            scaleX: 1,
          }}
          transition={{
            delay: bannerDelay,
            duration: 0.62,
            ease: [0.16, 1, 0.3, 1],
          }}
          style={{
            transformOrigin: "600px 555px",
          }}
        >
          <rect
            x="205"
            y="515"
            width="790"
            height="94"
            rx="24"
            fill="#020617"
            opacity="0.96"
            stroke={symbolColor}
            strokeWidth="4"
          />

          <rect
            x="220"
            y="530"
            width="760"
            height="64"
            rx="16"
            fill={teamData.colors.primary}
            opacity="0.2"
          />
        </motion.g>

        <motion.text
          x="600"
          y="577"
          textAnchor="middle"
          fill="#ffffff"
          fontSize={sloganFontSize}
          fontWeight="900"
          letterSpacing="4"
          initial={{
            opacity: 0,
            y: 11,
          }}
          animate={{
            opacity: 1,
            y: 0,
          }}
          transition={{
            delay: sloganDelay,
            duration: 0.52,
            ease: "easeOut",
          }}
        >
          {design.slogan}
        </motion.text>

        <motion.text
          x="600"
          y="577"
          textAnchor="middle"
          fill="#ffffff"
          fontSize={sloganFontSize}
          fontWeight="900"
          letterSpacing="4"
          filter={`url(#text-glow-${generationId})`}
          initial={{ opacity: 0 }}
          animate={{
            opacity: [0, 0, 0.55, 0],
          }}
          transition={{
            delay: sloganDelay,
            duration: 1.2,
            times: [0, 0.48, 0.72, 1],
          }}
          pointerEvents="none"
        >
          {design.slogan}
        </motion.text>

        <motion.ellipse
          cx="600"
          cy="350"
          rx="570"
          ry="285"
          fill={`url(#final-flash-${generationId})`}
          initial={{
            opacity: 0,
            scale: 0.88,
          }}
          animate={{
            opacity: [0, 0, 0.74, 0],
            scale: [0.88, 0.88, 1.04, 1.1],
          }}
          transition={{
            delay: finalPulseDelay,
            duration: 0.95,
            times: [0, 0.12, 0.44, 1],
            ease: "easeOut",
          }}
          style={{
            transformOrigin: "600px 350px",
          }}
          pointerEvents="none"
        />

        <path
          d="M0 640H1200L1075 720H125Z"
          fill={`url(#pitch-${generationId})`}
        />

        <path
          d="M600 640V720"
          stroke="#ffffff"
          strokeOpacity="0.48"
          strokeWidth="3"
        />

        <ellipse
          cx="600"
          cy="682"
          rx="110"
          ry="36"
          fill="none"
          stroke="#ffffff"
          strokeOpacity="0.42"
          strokeWidth="3"
        />

        <motion.g
          initial={{ opacity: 0 }}
          animate={{ opacity: 1 }}
          transition={{
            delay: sloganDelay + 0.14,
            duration: 0.45,
          }}
        >
          <text
            x="70"
            y="628"
            fill="#cbd5e1"
            fontSize="18"
            fontWeight="800"
            letterSpacing="3"
          >
            TIFO FORGE
          </text>

          <text
            x="1130"
            y="628"
            textAnchor="end"
            fill="#cbd5e1"
            fontSize="18"
            fontWeight="800"
            letterSpacing="2"
          >
            {teamData.code} · CROWD INTENSITY{" "}
            {design.energy}
          </text>
        </motion.g>
      </motion.svg>
    </div>
  );
}

function getSelectionTeaser(
  team: TeamId,
  emotion: EmotionId,
  symbol: SymbolId,
) {
  const teamData = teams[team];
  const emotionData = emotions[emotion];
  const symbolData = symbols[symbol];

  return {
    kicker: `${teamData.code} · ${emotionData.label} · ${symbolData.label}`,
    title: emotionData.teaser,
    body: `${teamData.identityLine} The ${symbolData.label.toLowerCase()} will shape the visual story, while Gemini keeps the final chant hidden until the stadium reveal.`,
  };
}

function randomItem<T>(items: readonly T[]): T {
  return items[
    Math.floor(Math.random() * items.length)
  ];
}

export default function TifoForge() {
  const svgRef =
    useRef<SVGSVGElement | null>(null);

  const [selectedTeam, setSelectedTeam] =
    useState<TeamId>("croatia");

  const [selectedEmotion, setSelectedEmotion] =
    useState<EmotionId>("defy");

  const [selectedSymbol, setSelectedSymbol] =
    useState<SymbolId>("phoenix");

  const [design, setDesign] =
    useState<TifoDesign>(fallbackTifoDesign);

  const [source, setSource] =
    useState<"gemini" | "fallback" | null>(
      null,
    );

  const [generationId, setGenerationId] =
    useState(0);

  const [isGenerating, setIsGenerating] =
    useState(false);

  const [statusMessage, setStatusMessage] =
    useState("Ready to raise the stand.");

  const selectionTeaser = getSelectionTeaser(
    selectedTeam,
    selectedEmotion,
    selectedSymbol,
  );

  async function requestTifo(
    selection: TifoSelection,
  ) {
    setIsGenerating(true);

    setStatusMessage(
      "Gemini is directing the stadium display.",
    );

    try {
      const response = await fetch("/api/design", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify(selection),
      });

      const result =
        (await response.json()) as DesignResponse;

      if (!response.ok || !result.ok) {
        throw new Error(
          result.error ??
            "The design request failed.",
        );
      }

      setDesign(result.design);
      setSource(result.source);
      setGenerationId((current) => current + 1);

      setStatusMessage(
        result.source === "gemini"
          ? "Gemini directed the plan. The stand is raised."
          : "The safe fallback kept the stand alive.",
      );
    } catch (error) {
      console.error(error);

      setStatusMessage(
        error instanceof Error
          ? error.message
          : "The stadium could not raise the display.",
      );
    } finally {
      setIsGenerating(false);
    }
  }

  async function generateTifo() {
    await requestTifo({
      team: selectedTeam,
      emotion: selectedEmotion,
      symbol: selectedSymbol,
    });
  }

  async function surpriseMe() {
    const nextTeam = randomItem(teamIds);
    const nextEmotion = randomItem(emotionIds);

    let nextSymbol = randomItem(symbolIds);

    if (
      nextTeam === selectedTeam &&
      nextEmotion === selectedEmotion &&
      nextSymbol === selectedSymbol
    ) {
      nextSymbol =
        symbolIds[
          (symbolIds.indexOf(nextSymbol) + 1) %
            symbolIds.length
        ];
    }

    setSelectedTeam(nextTeam);
    setSelectedEmotion(nextEmotion);
    setSelectedSymbol(nextSymbol);

    await requestTifo({
      team: nextTeam,
      emotion: nextEmotion,
      symbol: nextSymbol,
    });
  }

  function replayReveal() {
    setGenerationId((current) => current + 1);

    setStatusMessage(
      "The stadium reveal was replayed.",
    );
  }

  function downloadPoster() {
    const svg = svgRef.current;

    if (!svg) {
      setStatusMessage(
        "The poster is not ready to download yet.",
      );

      return;
    }

    const clonedSvg =
      svg.cloneNode(true) as SVGSVGElement;

    clonedSvg.setAttribute(
      "xmlns",
      "http://www.w3.org/2000/svg",
    );

    clonedSvg.setAttribute("width", "1200");
    clonedSvg.setAttribute("height", "720");

    const serializer = new XMLSerializer();

    const svgText =
      serializer.serializeToString(clonedSvg);

    const blob = new Blob([svgText], {
      type: "image/svg+xml;charset=utf-8",
    });

    const downloadUrl =
      URL.createObjectURL(blob);

    const link =
      document.createElement("a");

    link.href = downloadUrl;

    link.download =
      `tifo-forge-${selectedTeam}-${selectedEmotion}.svg`;

    document.body.appendChild(link);
    link.click();
    link.remove();

    URL.revokeObjectURL(downloadUrl);

    setStatusMessage(
      "Your stadium poster has been downloaded.",
    );
  }

  return (
    <main className={styles.page}>
      <div className={styles.appShell}>
        <header className={styles.header}>
          <div>
            <div className={styles.eyebrow}>
              Google Gemini · Built for passion
            </div>

            <h1>
              Tifo <span>Forge</span>
            </h1>
          </div>

          <p>
            Turn one supporter emotion into a
            stadium-wide display.
          </p>
        </header>

        <div className={styles.workspace}>
          <aside className={styles.controls}>
            <section>
              <div className={styles.sectionLabel}>
                1 · Team
              </div>

              <div className={styles.teamGrid}>
                {teamIds.map((teamId) => {
                  const team = teams[teamId];

                  const active =
                    selectedTeam === teamId;

                  return (
                    <button
                      key={teamId}
                      type="button"
                      className={
                        active
                          ? styles.teamActive
                          : styles.teamButton
                      }
                      onClick={() =>
                        setSelectedTeam(teamId)
                      }
                    >
                      <span>{team.flag}</span>
                      <strong>{team.code}</strong>
                    </button>
                  );
                })}
              </div>
            </section>

            <section>
              <div className={styles.sectionLabel}>
                2 · Passion
              </div>

              <div className={styles.passionGrid}>
                {emotionIds.map((emotionId) => (
                  <button
                    key={emotionId}
                    type="button"
                    className={
                      selectedEmotion === emotionId
                        ? styles.choiceActive
                        : styles.choiceButton
                    }
                    onClick={() =>
                      setSelectedEmotion(emotionId)
                    }
                  >
                    {emotions[emotionId].label}
                  </button>
                ))}
              </div>
            </section>

            <section>
              <div className={styles.sectionLabel}>
                3 · Symbol
              </div>

              <div className={styles.symbolGrid}>
                {symbolIds.map((symbolId) => (
                  <button
                    key={symbolId}
                    type="button"
                    title={symbols[symbolId].label}
                    aria-label={
                      symbols[symbolId].label
                    }
                    className={
                      selectedSymbol === symbolId
                        ? styles.symbolActive
                        : styles.symbolButton
                    }
                    onClick={() =>
                      setSelectedSymbol(symbolId)
                    }
                  >
                    <svg viewBox="0 0 100 100">
                      <SymbolGlyph
                        symbol={symbolId}
                        color="currentColor"
                      />
                    </svg>

                    {teams[selectedTeam].recommendedSymbols.includes(
                      symbolId,
                    ) && (
                      <span className={styles.bestFitBadge}>
                        Best fit
                      </span>
                    )}
                  </button>
                ))}
              </div>
            </section>

            <AnimatePresence mode="wait">
              <motion.div
                key={`${selectedTeam}-${selectedEmotion}-${selectedSymbol}`}
                className={styles.selectionPreview}
                initial={{
                  opacity: 0,
                  y: 9,
                  scale: 0.985,
                }}
                animate={{
                  opacity: 1,
                  y: 0,
                  scale: 1,
                }}
                exit={{
                  opacity: 0,
                  y: -7,
                  scale: 0.99,
                }}
                transition={{
                  duration: 0.32,
                  ease: [0.16, 1, 0.3, 1],
                }}
              >
                <div className={styles.previewTopLine}>
                  <span>{selectionTeaser.kicker}</span>

                  <div
                    className={styles.palettePreview}
                    aria-label={`${teams[selectedTeam].name} color palette`}
                  >
                    <motion.i
                      layout
                      style={{
                        background:
                          teams[selectedTeam].colors.primary,
                      }}
                    />
                    <motion.i
                      layout
                      style={{
                        background:
                          teams[selectedTeam].colors.secondary,
                      }}
                    />
                    <motion.i
                      layout
                      style={{
                        background:
                          teams[selectedTeam].colors.accent,
                      }}
                    />
                  </div>
                </div>

                <strong>{selectionTeaser.title}</strong>

                <p>{selectionTeaser.body}</p>

                <small>
                  Final words remain sealed until the reveal.
                </small>
              </motion.div>
            </AnimatePresence>

            <button
              type="button"
              className={styles.raiseButton}
              onClick={generateTifo}
              disabled={isGenerating}
            >
              {isGenerating
                ? "Directing..."
                : "Raise the tifo"}
            </button>

            <button
              type="button"
              className={styles.surpriseButton}
              onClick={surpriseMe}
              disabled={isGenerating}
            >
              Surprise me
            </button>

            <p
              className={styles.statusMessage}
              aria-live="polite"
            >
              {statusMessage}
            </p>
          </aside>

          <section className={styles.previewColumn}>
            <StadiumPreview
              team={selectedTeam}
              emotion={selectedEmotion}
              symbol={selectedSymbol}
              design={design}
              generationId={generationId}
              isGenerating={isGenerating}
              svgRef={svgRef}
            />

            <div className={styles.actionRow}>
              <button
                type="button"
                onClick={replayReveal}
                className={styles.secondaryAction}
                disabled={isGenerating}
              >
                Replay reveal
              </button>

              <button
                type="button"
                onClick={downloadPoster}
                className={styles.secondaryAction}
                disabled={isGenerating}
              >
                Download poster
              </button>
            </div>

            <div className={styles.resultBar}>
              <div>
                <span>Creative direction</span>

                <p>{design.designReason}</p>
              </div>

              <div className={styles.resultMeta}>
                <span>
                  {source === "gemini"
                    ? "Google Gemini"
                    : source === "fallback"
                      ? "Safe fallback"
                      : "Ready"}
                </span>

                <strong>
                  {design.energy}/100
                </strong>

                <small>Crowd intensity</small>
              </div>
            </div>
          </section>
        </div>
      </div>
    </main>
  );
}
