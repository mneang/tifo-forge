                aria-label="Choose a supporter passion"
              >
                {emotionIds.map((emotionId) => (
                  <button
                    key={emotionId}
                    type="button"
                    aria-pressed={
                      hasChosenEmotion &&
                      selectedEmotion === emotionId
                    }
                    aria-label={`Choose ${emotions[emotionId].label}`}
                    className={
                      hasChosenEmotion &&
                      selectedEmotion === emotionId
                        ? styles.choiceActive
                        : styles.choiceButton
                    }
                    onClick={() => {
                      setSelectedEmotion(emotionId);
                      setHasChosenEmotion(true);
                      setStatusMessage(
                        "Passion selected. Choose the symbol.",
                      );
                    }}
                  >
                    {emotions[emotionId].label}
                  </button>
                ))}
              </div>
            </section>

            <section>
              <div className={styles.sectionLabel}>
                3 · Symbol
              </div>

              <div
                className={styles.symbolGrid}
                role="group"
                aria-label="Choose a visual symbol"
              >
                {symbolIds.map((symbolId) => (
                  <button
                    key={symbolId}
                    type="button"
                    title={symbols[symbolId].label}
                    aria-label={`Choose ${symbols[symbolId].label}`}
                    aria-pressed={
                      hasChosenSymbol &&
                      selectedSymbol === symbolId
                    }
                    className={
                      hasChosenSymbol &&
                      selectedSymbol === symbolId
