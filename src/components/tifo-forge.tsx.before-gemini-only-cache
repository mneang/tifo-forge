                          <div
                            className={styles.palettePreview}
                            aria-label={`${teams[selectedTeam].name} palette`}
                          >
                            <i
                              style={{
                                background:
                                  teams[selectedTeam].colors.primary,
                              }}
                            />
                            <i
                              style={{
                                background:
                                  teams[selectedTeam].colors.secondary,
                              }}
                            />
                            <i
                              style={{
                                background:
                                  teams[selectedTeam].colors.accent,
                              }}
                            />
                          </div>
                        )}
                      </div>
                    </div>

                    <strong className={styles.previewTitle}>
                      {!hasChosenEmotion
                        ? "Now choose the feeling."
                        : !hasChosenSymbol
                          ? emotions[selectedEmotion].teaser
                          : selectionTeaser.title}
                    </strong>

                    <div className={styles.selectionFormula}>
                      <span
                        className={
                          hasChosenTeam
                            ? styles.formulaComplete
                            : styles.formulaPending
                        }
                      >
                        {hasChosenTeam
                          ? `${teams[selectedTeam].flag} ${teams[selectedTeam].code}`
                          : "Team"}
                      </span>

                      <b>+</b>

                      <span
                        className={
                          hasChosenEmotion
                            ? styles.formulaComplete
                            : styles.formulaPending
                        }
                      >
                        {hasChosenEmotion
                          ? emotions[selectedEmotion].label
                          : "Passion"}
                      </span>

                      <b>+</b>

                      <span
                        className={
                          hasChosenSymbol
                            ? styles.formulaComplete
                            : styles.formulaPending
                        }
                      >
                        {hasChosenSymbol
                          ? symbols[selectedSymbol].label
                          : "Symbol"}
                      </span>

                      <b>→</b>

                      <em>
                        {isSelectionComplete
                          ? "Hidden chant"
                          : `${selectionCount}/3 ready`}
                      </em>
                    </div>

                    <p className={styles.previewSummary}>
                      {!hasChosenTeam
                        ? "Choose a team to unlock its national palette."
                        : !hasChosenEmotion
                          ? teams[selectedTeam].identityLine
                          : !hasChosenSymbol
                            ? emotions[selectedEmotion].description
                            : `${teams[selectedTeam].identityLine} The ${symbols[
                                selectedSymbol
                              ].label.toLowerCase()} shapes the final reveal.`}
                    </p>
                  </>
                )}
              </motion.div>
            </AnimatePresence>

            <button
              type="button"
              className={styles.raiseButton}
              onClick={generateTifo}
              disabled={
                isGenerating || !isSelectionComplete
              }
            >
              {isGenerating
                ? "Directing..."
                : isSelectionComplete
                  ? "Raise the tifo"
                  : `Select ${3 - selectionCount} more`}
            </button>

            <button
              type="button"
              className={styles.surpriseButton}
              onClick={surpriseMe}
              disabled={isGenerating}
            >
              Surprise me
            </button>

            <p
              className={styles.statusMessage}
              aria-live="polite"
            >
              {statusMessage}
            </p>
          </aside>

          <section className={styles.previewColumn}>
            <StadiumPreview
              team={selectedTeam}
              emotion={selectedEmotion}
              symbol={selectedSymbol}
              design={design}
              generationId={generationId}
              isGenerating={isGenerating}
              svgRef={svgRef}
            />

            <div className={styles.actionRow}>
              <button
                type="button"
                onClick={replayReveal}
                className={styles.secondaryAction}
                disabled={isGenerating}
              >
                Replay reveal
              </button>

              <button
                type="button"
                onClick={downloadPoster}
                className={styles.secondaryAction}
                disabled={isGenerating}
              >
                Download poster
              </button>
            </div>

            <div className={styles.resultBar}>
              <div>
                <span>Creative direction</span>

                <p>{design.designReason}</p>
              </div>

              <div className={styles.resultMeta}>
                <span>
                  {source === "gemini"
                    ? "Google Gemini"
                    : source === "fallback"
                      ? "Safe fallback"
                      : "Ready"}
                </span>

                <strong>
                  {design.energy}/100
                </strong>

                <small>Crowd intensity</small>
              </div>
            </div>
          </section>
        </div>
      </div>
    </main>
  );
}
