function hexToRgb(hex: string) {
  const cleanHex = hex.replace("#", "");

  if (cleanHex.length !== 6) {
    return { r: 255, g: 255, b: 255 };
  }

  return {
    r: Number.parseInt(cleanHex.slice(0, 2), 16),
    g: Number.parseInt(cleanHex.slice(2, 4), 16),
    b: Number.parseInt(cleanHex.slice(4, 6), 16),
  };
}

function getLuminance(hex: string) {
  const { r, g, b } = hexToRgb(hex);

  const channels = [r, g, b].map((channel) => {
    const normalized = channel / 255;

    return normalized <= 0.03928
      ? normalized / 12.92
      : Math.pow((normalized + 0.055) / 1.055, 2.4);
  });

  return (
    channels[0] * 0.2126 +
    channels[1] * 0.7152 +
    channels[2] * 0.0722
  );
}

function pickHighContrastColor(palette: Palette) {
  const candidates = [
    palette.accent,
    palette.secondary,
    "#FFFFFF",
    "#F8FAFC",
  ];

  return candidates.sort(
    (first, second) =>
      getLuminance(second) - getLuminance(first),
  )[0];
}

function isSymbolSeat(
  symbol: SymbolId,
  row: number,
  column: number,
  rows: number,
  columns: number,
) {
  const x =
    (column - (columns - 1) / 2) / (columns / 2);

  const y =
    (row - (rows - 1) / 2) / (rows / 2);

  if (symbol === "heart") {
    const adjustedY = y + 0.08;

    const value =
      Math.pow(
        x * x +
          adjustedY * adjustedY -
          0.48,
        3,
      ) -
      x * x *
        Math.pow(adjustedY, 3);

    return value < 0 && adjustedY < 0.72;
  }

  if (symbol === "lightning") {
    const upperStroke =
      Math.abs(x + 0.24 - y * 0.28) < 0.13 &&
      y < 0.18;

    const lowerStroke =
      Math.abs(x - 0.12 - y * 0.36) < 0.13 &&
      y > -0.2;

    return upperStroke || lowerStroke;
  }

  if (symbol === "crown") {
    const base =
      y > 0.28 &&
      y < 0.58 &&
      Math.abs(x) < 0.64;

    const leftPoint =
      y > -0.42 &&
      y < 0.32 &&
      Math.abs(x + 0.48) <
        0.14 + (y + 0.42) * 0.22;

    const centerPoint =
      y > -0.66 &&
      y < 0.32 &&
      Math.abs(x) <
        0.13 + (y + 0.66) * 0.16;

    const rightPoint =
      y > -0.42 &&
      y < 0.32 &&
      Math.abs(x - 0.48) <
        0.14 + (y + 0.42) * 0.22;

    return base || leftPoint || centerPoint || rightPoint;
  }

  if (symbol === "rising-sun") {
    const horizon =
      Math.abs(y - 0.34) < 0.1 &&
      Math.abs(x) < 0.74;

    const sunriseArc =
      y > -0.05 &&
      y < 0.36 &&
      x * x + Math.pow(y - 0.34, 2) < 0.34;

    const openSky =
      y < 0.14 &&
      x * x + Math.pow(y - 0.34, 2) > 0.17 &&
      x * x + Math.pow(y - 0.34, 2) < 0.34;

    return horizon || (sunriseArc && !openSky);
  }

  if (symbol === "wings") {
    const leftWing =
      x < -0.06 &&
      x > -0.82 &&
      Math.abs(y - (-0.05 - x * 0.32)) < 0.16;

    const rightWing =
      x > 0.06 &&
      x < 0.82 &&
      Math.abs(y - (-0.05 + x * 0.32)) < 0.16;

    const spine =
      Math.abs(x) < 0.08 &&
      y > -0.38 &&
      y < 0.58;

    return leftWing || rightWing || spine;
  }

  const leftWing =
    x < -0.04 &&
    x > -0.78 &&
    Math.abs(y - (-0.08 - x * 0.36)) < 0.15;

  const rightWing =
    x > 0.04 &&
    x < 0.78 &&
    Math.abs(y - (-0.08 + x * 0.36)) < 0.15;

  const body =
    Math.abs(x) < 0.1 &&
    y > -0.54 &&
    y < 0.66;

  const tail =
    y > 0.32 &&
    Math.abs(x) < 0.28 - (y - 0.32) * 0.2;

  return leftWing || rightWing || body || tail;
}

function darkenHex(hex: string, factor: number) {
  const { r, g, b } = hexToRgb(hex);

  const clamp = (value: number) =>
    Math.max(0, Math.min(255, Math.round(value)));

  return `#${[
    clamp(r * factor),
    clamp(g * factor),
    clamp(b * factor),
  ]
    .map((channel) => channel.toString(16).padStart(2, "0"))
    .join("")}`;
}

function getSupporterBaseColor(
  team: TeamId,
  row: number,
  column: number,
  rows: number,
  columns: number,
  palette: Palette,
) {
  const x = column / Math.max(columns - 1, 1);
  const y = row / Math.max(rows - 1, 1);

  const centerX =
    (column - (columns - 1) / 2) / (columns / 2);

  const centerY =
    (row - (rows - 1) / 2) / (rows / 2);

  /*
   * These are abstract supporter patterns based only on
   * contemporary national-team palettes.
   *
   * They intentionally avoid reproducing historical,
   * military, colonial, imperial, or political flags.
   */

  if (team === "argentina") {
    const verticalRibbon =
      Math.floor(x * 6) % 2 === 0;

    const goldCore =
      Math.abs(centerX) < 0.1 &&
      Math.abs(centerY) < 0.3;

    if (goldCore) {
      return palette.accent;
    }

    return verticalRibbon
      ? palette.primary
      : palette.secondary;
  }

  if (team === "brazil") {
    const centralDiamond =
      Math.abs(centerX) * 0.95 +
        Math.abs(centerY) <
      0.62;

    const innerCore =
      centerX * centerX +
        centerY * centerY <
      0.11;

    if (innerCore) {
      return palette.accent;
    }

    return centralDiamond
      ? palette.primary
      : palette.secondary;
  }

  if (team === "croatia") {
    const largeBlock =
      (Math.floor(column / 4) +
        Math.floor(row / 3)) %
      2;

    const blueFoundation =
      y > 0.8;

    if (blueFoundation) {
      return palette.accent;
    }

    return largeBlock === 0
      ? palette.primary
      : palette.secondary;
  }

  if (team === "france") {
    if (x < 0.32) {
      return palette.primary;
    }

    if (x > 0.68) {
      return palette.accent;
    }

    return palette.secondary;
  }

  if (team === "japan") {
    const redCore =
      centerX * centerX +
        centerY * centerY <
      0.18;

    const blueFoundation =
      y > 0.78;

    const blueCrown =
      y < 0.08;

    if (redCore) {
      return palette.accent;
    }

    if (blueFoundation || blueCrown) {
      return palette.primary;
    }

    return palette.secondary;
  }

  if (team === "morocco") {
    const greenChevron =
      Math.abs(
        Math.abs(centerX) +
          centerY * 0.68 -
          0.42,
      ) < 0.12;

    const goldCore =
      centerX * centerX +
        centerY * centerY <
      0.07;

    if (goldCore) {
      return palette.accent;
    }

    return greenChevron
      ? palette.secondary
      : palette.primary;
  }

  if (team === "spain") {
    const goldCenter =
      y > 0.27 &&
      y < 0.73;

    const blueEdge =
      x < 0.045 ||
      x > 0.955;

    if (blueEdge) {
      return palette.accent;
    }

    return goldCenter
      ? palette.secondary
      : palette.primary;
  }

  const navyCrown =
    y < 0.25;

  const horizontalBand =
    Math.floor(y * 8) % 2 === 0;

  if (navyCrown) {
    return palette.primary;
  }

  return horizontalBand
    ? palette.accent
    : palette.secondary;
}

function getSeatColor(
  team: TeamId,
  emotion: EmotionId,
  layout: TifoDesign["layout"],
  symbol: SymbolId,
  row: number,
  column: number,
  rows: number,
  columns: number,
  palette: Palette,
  symbolColor: string,
) {
  if (
    isSymbolSeat(
      symbol,
      row,
      column,
      rows,
      columns,
    )
  ) {
    return symbolColor;
  }

  const centerRow = (rows - 1) / 2;
  const centerColumn = (columns - 1) / 2;

  const normalizedX =
    (column - centerColumn) / (columns / 2);

  const normalizedY =
    (row - centerRow) / (rows / 2);

  const centerDistance = Math.sqrt(
    normalizedX * normalizedX +
      normalizedY * normalizedY,
  );

  let baseColor = getSupporterBaseColor(
    team,
    row,
    column,
    rows,
    columns,
    palette,
  );

  /*
   * Passion overlays are intentionally restrained.
   * They add direction without destroying the team identity.
   */

  if (emotion === "believe") {
    const upwardPath =
      Math.abs(normalizedX) <
      0.045 + (normalizedY + 1) * 0.075;

    const liftedShoulders =
      normalizedY < -0.28 &&
      Math.abs(normalizedX) <
        0.2 + Math.abs(normalizedY) * 0.32;

    if (
      (upwardPath && normalizedY < 0.58) ||
      liftedShoulders
    ) {
      baseColor = palette.accent;
    }
  }

  if (emotion === "defy") {
    const diagonal =
      normalizedX -
      normalizedY * 0.72;

    const counterDiagonal =
      normalizedX +
      normalizedY * 0.58;

    if (
      (diagonal > -0.035 &&
        diagonal < 0.09) ||
      (
        counterDiagonal > 0.52 &&
        counterDiagonal < 0.59
      )
    ) {
      baseColor = palette.accent;
    }
  }

  if (emotion === "unite") {
    const leftConvergence =
      normalizedX < 0 &&
      Math.abs(
        normalizedX +
          0.42 +
          normalizedY * 0.24
      ) < 0.1;

    const rightConvergence =
      normalizedX > 0 &&
      Math.abs(
        normalizedX -
          0.42 -
          normalizedY * 0.24
      ) < 0.1;

    const centerRibbon =
      Math.abs(normalizedX) <
      0.055 + Math.abs(normalizedY) * 0.055;

    if (
      leftConvergence ||
      rightConvergence ||
      centerRibbon
    ) {
      baseColor = palette.accent;
    }
  }

  if (emotion === "remember") {
    const tributeBand =
      normalizedY > 0.25 &&
      normalizedY < 0.4;

    const quietCenter =
      Math.abs(normalizedX) < 0.045 &&
      normalizedY > -0.58 &&
      normalizedY < 0.64;

    if (tributeBand || quietCenter) {
      baseColor = palette.accent;
    }
  }

  /*
   * Create a soft, controlled clearing around the emblem.
   * This prevents the center from becoming visually noisy.
   */

  if (centerDistance < 0.24) {
    return darkenHex(baseColor, 0.32);
  }

  if (centerDistance < 0.38) {
    return darkenHex(baseColor, 0.64);
  }

  /*
   * Gemini's layout choice adds only a final accent,
   * never a second competing pattern.
   */

  if (layout === "diagonal-rise") {
    const diagonal =
      normalizedX -
      normalizedY * 0.75;

    if (
      diagonal > 0.28 &&
      diagonal < 0.36
    ) {
      return palette.accent;
    }
  }

  if (
    layout === "split-banner" &&
    Math.abs(normalizedX) < 0.045
  ) {
    return palette.accent;
  }

  if (
    layout === "radiating-burst" &&
    centerDistance > 0.52 &&
    centerDistance < 0.6
  ) {
    return palette.accent;
  }

  return baseColor;
}

function getPassionMotion(emotion: EmotionId) {
  if (emotion === "defy") {
    return {
      initial: {
        opacity: 0,
        x: -34,
        y: 14,
        skewX: -4,
        scale: 0.98,
      },
      animate: {
        opacity: [0, 1, 1],
        x: [-34, 8, 0],
        y: [14, -3, 0],
        skewX: [-4, 1, 0],
        scale: [0.98, 1.025, 1],
      },
    };
  }

  if (emotion === "unite") {
    return {
      initial: {
        opacity: 0,
        scaleX: 0.72,
        scaleY: 0.96,
      },
      animate: {
        opacity: [0, 1, 1],
        scaleX: [0.72, 1.035, 1],
        scaleY: [0.96, 1.015, 1],
      },
    };
  }

  if (emotion === "remember") {
    return {
      initial: {
        opacity: 0,
        y: 5,
        scale: 0.975,
      },
      animate: {
        opacity: [0, 0.72, 1],
        y: [5, 1, 0],
        scale: [0.975, 1.008, 1],
      },
    };
  }

  return {
    initial: {
      opacity: 0,
      y: 32,
      scale: 0.97,
    },
    animate: {
      opacity: [0, 1, 1],
      y: [32, -7, 0],
      scale: [0.97, 1.025, 1],
    },
  };
}

function getSloganFontSize(slogan: string) {
  if (slogan.length <= 12) {
    return 58;
  }

  if (slogan.length <= 18) {
    return 52;
  }

  if (slogan.length <= 22) {
    return 46;
  }

  return 41;
}

function StadiumPreview({
  team,
  emotion,
  symbol,
  design,
  generationId,
  isGenerating,
  svgRef,
}: {
  team: TeamId;
  emotion: EmotionId;
  symbol: SymbolId;
  design: TifoDesign;
  generationId: number;
  isGenerating: boolean;
  svgRef: RefObject<SVGSVGElement | null>;
}) {
  const teamData = teams[team];

  const rows = 13;
  const columns = 30;

  const seats = useMemo(
    () =>
      Array.from(
        { length: rows * columns },
        (_, index) => {
          const row = Math.floor(index / columns);
          const column = index % columns;
          const rowProgress =
            row / Math.max(rows - 1, 1);

          const rowWidth = 820 + row * 19;
          const gap = rowWidth / columns;
          const startX = 600 - rowWidth / 2;

          const normalizedColumn =
            (column - (columns - 1) / 2) /
            ((columns - 1) / 2);

          const rowCurve =
            Math.pow(Math.abs(normalizedColumn), 1.7) *
            (8 + rowProgress * 10);

          const perspectiveDrop =
            rowProgress * rowProgress * 13;

          return {
            index,
            row,
            column,
            x: startX + column * gap + 3,
            y:
              170 +
              row * 27 +
              rowCurve +
              perspectiveDrop,
            width: Math.max(18, gap - 6),
            height: 16 + rowProgress * 3,
          };
        },
      ),
    [],
  );

  const intensity =
    Math.max(60, Math.min(100, design.energy)) / 100;

  const revealDuration =
    emotion === "remember"
      ? 1.75
      : 1.55 - intensity * 0.22;

  const symbolDelay = revealDuration * 0.47;
  const bannerDelay = revealDuration * 0.68;
  const sloganDelay = revealDuration * 0.82;
  const finalPulseDelay = sloganDelay + 0.48;

  const symbolColor = pickHighContrastColor(
    teamData.colors,
  );

  const outlineColor =
    getLuminance(symbolColor) > 0.65
      ? "#020617"
      : "#FFFFFF";

  const passionMotion =
    getPassionMotion(emotion);

  const sloganFontSize =
    getSloganFontSize(design.slogan);

  return (
    <div className={styles.stadiumShell}>
      {isGenerating && (
        <motion.div
          className={styles.loadingOverlay}
          initial={{ opacity: 0 }}
          animate={{ opacity: 1 }}
        >
          <motion.div
            className={styles.loadingPill}
            animate={{
              scale: [1, 1.035, 1],
            }}
            transition={{
              duration: 1,
              repeat: Infinity,
              ease: "easeInOut",
            }}
          >
            <span />
            Gemini is directing the stand
          </motion.div>
        </motion.div>
      )}

      <motion.svg
        ref={svgRef}
        key={generationId}
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 1200 720"
        className={styles.stadium}
        initial={{
          opacity: 0.92,
          scale: 0.992,
          y: 4,
        }}
        animate={{
          opacity: 1,
          scale: [0.992, 1.012, 1],
          y: [4, -3, 0],
        }}
        transition={{
          duration: finalPulseDelay + 0.9,
          times: [0, 0.74, 1],
          ease: [0.16, 1, 0.3, 1],
        }}
        role="img"
        aria-label={`${teamData.name} supporter tifo reading ${design.slogan}`}
      >
        <defs>
          <linearGradient
            id={`sky-${generationId}`}
            x1="0"
            y1="0"
            x2="0"
            y2="1"
          >
            <stop offset="0%" stopColor="#020617" />
            <stop offset="50%" stopColor="#111c36" />
            <stop offset="100%" stopColor="#020617" />
          </linearGradient>

          <linearGradient
            id={`pitch-${generationId}`}
            x1="0"
            y1="0"
            x2="0"
            y2="1"
          >
            <stop offset="0%" stopColor="#166534" />
            <stop offset="100%" stopColor="#052e16" />
          </linearGradient>

          <linearGradient
            id={`shine-${generationId}`}
            x1="0"
            y1="0"
            x2="1"
            y2="0"
          >
            <stop
              offset="0%"
              stopColor="#ffffff"
              stopOpacity="0"
            />
            <stop
              offset="50%"
              stopColor="#ffffff"
              stopOpacity="0.24"
            />
            <stop
              offset="100%"
              stopColor="#ffffff"
              stopOpacity="0"
            />
          </linearGradient>

          <radialGradient
            id={`final-flash-${generationId}`}
          >
            <stop
              offset="0%"
              stopColor="#ffffff"
              stopOpacity="0.44"
            />
            <stop
              offset="52%"
              stopColor={teamData.colors.primary}
              stopOpacity="0.18"
            />
            <stop
              offset="100%"
              stopColor={teamData.colors.primary}
              stopOpacity="0"
            />
          </radialGradient>

          <filter
            id={`glow-${generationId}`}
            x="-80%"
            y="-80%"
            width="260%"
            height="260%"
