                        setStatusMessage(
                          "Team selected. Choose the passion.",
                        );
                      }}
                    >
                      <span>{team.flag}</span>
                      <strong>{team.code}</strong>
                    </button>
                  );
                })}
              </div>
            </section>

            <section>
