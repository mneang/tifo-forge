function getSelectionTeaser(
  team: TeamId,
  emotion: EmotionId,
  symbol: SymbolId,
) {
  const teamData = teams[team];
  const emotionData = emotions[emotion];
  const symbolData = symbols[symbol];

  return {
    kicker: `${teamData.code} · ${emotionData.label} · ${symbolData.label}`,
    title: emotionData.teaser,
    body: `${teamData.identityLine} The ${symbolData.label.toLowerCase()} will shape the reveal.`,
  };
}

function randomItem<T>(items: readonly T[]): T {
  return items[
    Math.floor(Math.random() * items.length)
  ];
}

export default function TifoForge() {
  const svgRef =
    useRef<SVGSVGElement | null>(null);

  const [selectedTeam, setSelectedTeam] =
    useState<TeamId>("croatia");

  const [selectedEmotion, setSelectedEmotion] =
    useState<EmotionId>("defy");

  const [selectedSymbol, setSelectedSymbol] =
    useState<SymbolId>("phoenix");

  const [hasChosenTeam, setHasChosenTeam] =
    useState(false);

  const [hasChosenEmotion, setHasChosenEmotion] =
    useState(false);

  const [hasChosenSymbol, setHasChosenSymbol] =
    useState(false);

  const [design, setDesign] =
    useState<TifoDesign>(fallbackTifoDesign);

  const [source, setSource] =
    useState<"gemini" | "fallback" | null>(
      null,
    );

  const [generationId, setGenerationId] =
    useState(0);

  const [isGenerating, setIsGenerating] =
    useState(false);

  const [statusMessage, setStatusMessage] =
    useState("Ready to raise the stand.");

  const selectionTeaser = getSelectionTeaser(
    selectedTeam,
    selectedEmotion,
    selectedSymbol,
  );

  const selectedSymbolIsRecommended =
    teams[selectedTeam].recommendedSymbols.includes(
      selectedSymbol,
    );

  const selectionCount =
    Number(hasChosenTeam) +
    Number(hasChosenEmotion) +
    Number(hasChosenSymbol);

  const isSelectionComplete =
    hasChosenTeam &&
    hasChosenEmotion &&
    hasChosenSymbol;

  function resetSelection() {
    setHasChosenTeam(false);
    setHasChosenEmotion(false);
    setHasChosenSymbol(false);
    setSource(null);
    setStatusMessage(
      "Choose a team, a passion, and a symbol.",
    );
  }

  async function requestTifo(
    selection: TifoSelection,
  ) {
    setIsGenerating(true);

    const browserCacheKey =
      `tifo-forge:${selection.team}:${selection.emotion}:${selection.symbol}`;

    setStatusMessage(
      "Gemini is directing the stadium display.",
    );

    try {
      const cachedText =
        window.localStorage.getItem(browserCacheKey);

      if (cachedText) {
        const cachedResult =
          JSON.parse(cachedText) as DesignResponse;

        if (cachedResult.ok && cachedResult.design) {
          setDesign(cachedResult.design);
          setSource(cachedResult.source);
          setGenerationId(
            (current) => current + 1,
          );

          setStatusMessage(
            "Your saved creative plan has been raised instantly.",
          );

          return;
        }
      }
      const response = await fetch("/api/design", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify(selection),
      });

      const result =
        (await response.json()) as DesignResponse;

      if (!response.ok || !result.ok) {
        throw new Error(
          result.error ??
            "The design request failed.",
        );
      }

      setDesign(result.design);
      setSource(result.source);
      setGenerationId((current) => current + 1);

      window.localStorage.setItem(
        browserCacheKey,
        JSON.stringify(result),
      );

      setStatusMessage(
        result.source === "gemini"
          ? "Gemini directed the plan. The stand is raised."
          : "The safe fallback kept the stand alive.",
      );
    } catch (error) {
      console.error(error);

      setStatusMessage(
        error instanceof Error
          ? error.message
          : "The stadium could not raise the display.",
      );
    } finally {
      setIsGenerating(false);
    }
  }

  async function generateTifo() {
    if (!isSelectionComplete) {
      setStatusMessage(
        "Complete all three selections before raising the tifo.",
      );
      return;
    }

    await requestTifo({
      team: selectedTeam,
      emotion: selectedEmotion,
      symbol: selectedSymbol,
    });
  }

  async function surpriseMe() {
    const nextTeam = randomItem(teamIds);
    const nextEmotion = randomItem(emotionIds);

    let nextSymbol = randomItem(symbolIds);

    if (
      nextTeam === selectedTeam &&
      nextEmotion === selectedEmotion &&
      nextSymbol === selectedSymbol
    ) {
      nextSymbol =
        symbolIds[
          (symbolIds.indexOf(nextSymbol) + 1) %
            symbolIds.length
        ];
    }

    setSelectedTeam(nextTeam);
    setSelectedEmotion(nextEmotion);
    setSelectedSymbol(nextSymbol);
    setHasChosenTeam(true);
    setHasChosenEmotion(true);
    setHasChosenSymbol(true);

    await requestTifo({
      team: nextTeam,
      emotion: nextEmotion,
      symbol: nextSymbol,
    });
  }

  function replayReveal() {
    setGenerationId((current) => current + 1);

    setStatusMessage(
      "The stadium reveal was replayed.",
    );
  }

  function downloadPoster() {
    const svg = svgRef.current;

    if (!svg) {
      setStatusMessage(
        "The poster is not ready to download yet.",
      );

      return;
    }

    const clonedSvg =
      svg.cloneNode(true) as SVGSVGElement;

    clonedSvg.setAttribute(
      "xmlns",
      "http://www.w3.org/2000/svg",
    );

    clonedSvg.setAttribute("width", "1200");
    clonedSvg.setAttribute("height", "720");

    const serializer = new XMLSerializer();

    const svgText =
      serializer.serializeToString(clonedSvg);

    const blob = new Blob([svgText], {
      type: "image/svg+xml;charset=utf-8",
    });

    const downloadUrl =
      URL.createObjectURL(blob);

    const link =
      document.createElement("a");

    link.href = downloadUrl;

    link.download =
      `tifo-forge-${selectedTeam}-${selectedEmotion}.svg`;

    document.body.appendChild(link);
    link.click();
    link.remove();

    URL.revokeObjectURL(downloadUrl);

    setStatusMessage(
      "Your stadium poster has been downloaded.",
    );
  }

  return (
    <main className={styles.page}>
